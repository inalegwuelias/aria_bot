# ── Aria Discord Bot — Environment Variables ──────────────────────────────────
# Copy this file and rename it to .env, then fill in your actual keys.
# Never commit your .env file to GitHub!

# Discord Bot Token
# Get this from: https://discord.com/developers/applications → Your App → Bot → Token
DISCORD_TOKEN=your_discord_bot_token_here

# Groq API Key
# Get this from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
